# ─────────────────────────────────────────────────────────────
#  STAVARAI PLATFORM — ENVIRONMENT VARIABLES
#  Copy to .env and fill values. Never commit .env.
#  See docs/SECRETS.md for full contract.
# ─────────────────────────────────────────────────────────────

# ── Platform identity ─────────────────────────────────────
PLATFORM_NAME=Stavarai
DEMO_PASSWORD=BLASTER2026                          # change after demo
MASTER_ENCRYPTION_KEY=                             # openssl rand -hex 32  (32 bytes)

# ── Operating mode (frontend) ─────────────────────────────
# true  = standalone demo, no backend required (default for local dev)
# false = production, frontend calls FastAPI at API_URL
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=                              # server only — NEVER in frontend
SUPABASE_PROJECT_REF=                              # for `supabase link`
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=                     # read-only, safe for frontend

# ── AI providers (model-agnostic — one active at a time) ──
ACTIVE_LLM_PROVIDER=anthropic                      # anthropic|openai|google|ollama
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Hermes agent ──────────────────────────────────────────
HERMES_PROFILE=stavarai-platform
HERMES_MAX_CHILDREN=10

# ── Video generation (Higgsfield) ─────────────────────────
HIGGSFIELD_API_KEY=
HIGGSFIELD_MCP_URL=https://mcp.higgsfield.ai/mcp

# ── Social publishing (Buffer) ────────────────────────────
BUFFER_ACCESS_TOKEN=

# ── Research / scraping ───────────────────────────────────
APIFY_API_TOKEN=
FIRECRAWL_API_KEY=

# ── Client data (Airtable) ────────────────────────────────
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=apptABTHZ91toPYKi

# ── Voice control ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=                                  # integer — Stavarai's Telegram ID
VISIONCLAW_WEBHOOK_SECRET=

# ── Email ─────────────────────────────────────────────────
EMAIL_PROVIDER=resend                              # resend|sendgrid|postmark
EMAIL_API_KEY=
EMAIL_FROM=noreply@example.com

# ── Deploy ────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
API_URL=http://localhost:8000                      # public URL of FastAPI on the VPS

# ── GitHub ────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=executiveusa/buffer-blaster-
